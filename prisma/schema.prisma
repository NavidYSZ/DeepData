generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  name       String?
  email      String?   @unique
  emailVerified DateTime?
  image      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  gscAccounts GscAccount[]
  accounts   Account[]
  sessions   Session[]
  chatSessions ChatSession[]
  chatMessages ChatMessage[]
  chatFiles   ChatFile[]
  keywordProjects KeywordProject[]
  crawlRuns   CrawlRun[]
}

model GscAccount {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  email          String?
  refresh_token  String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Chat sessions per user
model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Neue Unterhaltung")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]
  files     ChatFile[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   // user | assistant | tool | system
  content    String   // JSON stringified content
  model      String?
  toolName   String?
  toolCallId String?
  createdAt  DateTime @default(now())
}

model ChatFile {
  id         String   @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename   String
  mime       String
  path       String
  size       Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

/// Keyword Workspace models (V1)
model KeywordProject {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  lang           String   @default("de")
  country        String   @default("DE")
  gscSiteUrl     String?
  gscDefaultDays Int      @default(28)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sources        KeywordSource[]
  keywords       Keyword[]
  keywordDemands KeywordDemand[]
  preclusters    Precluster[]
  clusters       Cluster[]
  events         WorkspaceEvent[]
  serpSnapshots  SerpSnapshot[]
  serpRuns       SerpClusterRun[]
  serpParents    SerpParentCluster[]
  serpSubclusters SerpSubcluster[]
}

model KeywordSource {
  id        String   @id @default(cuid())
  projectId String
  project   KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // "gsc" | "upload"
  name      String
  metaJson  String?
  createdAt DateTime @default(now())

  metrics   KeywordSourceMetric[]

  @@index([projectId, type])
}

model Keyword {
  id         String   @id @default(cuid())
  projectId  String
  project    KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kwRaw      String
  kwNorm     String
  kwSig      String
  lang       String?
  country    String?
  createdAt  DateTime @default(now())

  sourceMetrics     KeywordSourceMetric[]
  demand            KeywordDemand?
  preclusterMembers PreclusterMember[]
  clusterMembers    ClusterMember[]
  serpSnapshots     SerpSnapshot[]
  serpSubclusterMembers SerpSubclusterMember[]

  @@index([projectId, kwNorm])
  @@index([projectId, kwSig])
}

model KeywordSourceMetric {
  keywordId     String
  sourceId      String
  keyword       Keyword       @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  source        KeywordSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  impressions   Int?
  clicks        Int?
  position      Float?
  sistrixVolume Int?
  cpc           Float?
  kd            Float?
  url           String?
  dateFrom      DateTime?
  dateTo        DateTime?

  @@id([keywordId, sourceId])
}

model KeywordDemand {
  keywordId     String   @id
  keyword       Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  projectId     String
  project       KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  demandMonthly Float
  demandSource  String   // "gsc" | "upload" | "none"
  computedAt    DateTime @default(now())

  @@index([projectId, demandMonthly])
}

model Precluster {
  id           String   @id @default(cuid())
  projectId    String
  project      KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  algoVersion  String
  label        String
  totalDemand  Float
  cohesion     Float
  createdAt    DateTime @default(now())

  members      PreclusterMember[]

  @@index([projectId, totalDemand])
}

model PreclusterMember {
  preclusterId String
  keywordId    String
  precluster   Precluster @relation(fields: [preclusterId], references: [id], onDelete: Cascade)
  keyword      Keyword    @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  score        Float

  @@id([preclusterId, keywordId])
  @@index([keywordId])
}

model Cluster {
  id          String   @id @default(cuid())
  projectId   String
  project     KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     ClusterMember[]
}

model ClusterMember {
  clusterId String
  keywordId String
  cluster   Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  keyword   Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@id([clusterId, keywordId])
}

model WorkspaceEvent {
  id         String   @id @default(cuid())
  projectId  String
  project    KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type       String
  payloadJson String
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}

/// SERP-based clustering (URL overlap + parent mapping)
model SerpSnapshot {
  id         String   @id @default(cuid())
  projectId  String
  project    KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keywordId  String
  keyword    Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  provider   String   @default("zyte")
  fetchedAt  DateTime
  status     String
  httpStatus Int?
  durationMs Int?
  topUrlsJson String? // normalized urls + positions
  rawJson     String?
  hash        String?
  error       String?

  @@index([projectId, fetchedAt])
  @@index([keywordId])
}

model SerpClusterRun {
  id                 String   @id @default(cuid())
  projectId          String
  project            KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status             String   @default("pending") // pending | running | failed | completed
  startedAt          DateTime @default(now())
  finishedAt         DateTime?
  urlOverlapThreshold Float   @default(0.3)
  minDemand          Float    @default(0)
  topResults         Int      @default(10)
  clusterAlgorithm   String   @default("louvain")
  snapshotReuseMode  String   @default("reuse_any_fetch_missing")
  missingSnapshotCount Int    @default(0)
  fetchedMissingCount Int     @default(0)
  eligibleKeywordCount Int    @default(0)
  resolvedKeywordCount Int    @default(0)
  usedKeywordCount   Int      @default(0)
  waveCount          Int      @default(0)
  zyteRequested      Int      @default(0)
  zyteSucceeded      Int      @default(0)
  zyteCached         Int      @default(0)
  promptModel        String?
  error              String?

  subclusters        SerpSubcluster[]
  parents            SerpParentCluster[]

  @@index([projectId, startedAt])
}

model SerpSubcluster {
  id           String   @id @default(cuid())
  runId        String
  run          SerpClusterRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  projectId    String
  project      KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  totalDemand  Float
  keywordCount Int
  overlapScore Float?
  topDomainsJson String?
  topUrlsJson    String?

  members      SerpSubclusterMember[]
  parents      SerpParentToSubcluster[]

  @@index([projectId])
  @@index([runId])
}

model SerpSubclusterMember {
  subclusterId String
  keywordId    String
  subcluster   SerpSubcluster @relation(fields: [subclusterId], references: [id], onDelete: Cascade)
  keyword      Keyword        @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@id([subclusterId, keywordId])
  @@index([keywordId])
}

model SerpParentCluster {
  id           String   @id @default(cuid())
  runId        String
  run          SerpClusterRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  projectId    String
  project      KeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  rationale    String?
  totalDemand  Float
  keywordCount Int
  topDomainsJson String?

  subclusters  SerpParentToSubcluster[]

  @@index([projectId])
  @@index([runId])
}

model SerpParentToSubcluster {
  parentId    String
  subclusterId String
  parent      SerpParentCluster @relation(fields: [parentId], references: [id], onDelete: Cascade)
  subcluster  SerpSubcluster    @relation(fields: [subclusterId], references: [id], onDelete: Cascade)

  @@id([parentId, subclusterId])
  @@index([subclusterId])
}

/// Internal-link analysis: one crawl run captures a full snapshot of a site's
/// pages and internal links. Subsequent runs do not mutate prior rows, so
/// historical comparisons fall out for free.
model CrawlRun {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteUrl     String
  seedUrl     String
  status      String   @default("running") // running | completed | failed
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  urlsCrawled Int      @default(0)
  linksFound  Int      @default(0)
  maxUrls     Int      @default(500)
  error       String?

  snapshots   UrlSnapshot[]
  links       InternalLink[]

  @@index([userId, startedAt])
}

model UrlSnapshot {
  id          String   @id @default(cuid())
  runId       String
  run         CrawlRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  url         String
  title       String?
  h1          String?
  canonical   String?
  statusCode  Int?
  indexable   Boolean  @default(true)
  pageType    String   @default("other") // hub | category | product | guide | service | other
  cluster     String   @default("uncategorised")
  position    Float?
  impressions Int?
  clicks      Int?
  // Stringified TopQuery[] (lib/internal-links/types.ts). JSON because SQLite
  // has no JSON type and a separate row table is overkill for ~10 queries/URL.
  topQueriesJson String?

  inboundLinks  InternalLink[] @relation("InboundLinks")
  outboundLinks InternalLink[] @relation("OutboundLinks")

  @@unique([runId, url])
  @@index([runId])
}

model InternalLink {
  id           String   @id @default(cuid())
  runId        String
  run          CrawlRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  sourceId     String
  source       UrlSnapshot @relation("OutboundLinks", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId     String
  target       UrlSnapshot @relation("InboundLinks", fields: [targetId], references: [id], onDelete: Cascade)
  anchorText   String
  anchorClass  String   // exact | partial | branded | entity | generic | empty | image_no_alt
  placement    String   // content | navigation | footer | sidebar | image
  isContextual Boolean  @default(false)
  isNofollow   Boolean  @default(false)

  @@index([runId, targetId])
  @@index([runId, sourceId])
}
